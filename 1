<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="7월 25일(토) 대영베이스CC · 티오프 17:25 / 17:32 · 집결 17:30">
<meta property="og:title" content="그린모먼트 7/25(토) 야간 정기 라운딩">
<meta property="og:description" content="대영베이스CC · 집결 17:30 · 티오프 17:25 / 17:32 · 시상 및 저녁 안내">
<meta property="og:type" content="website">
<meta name="theme-color" content="#0A1D15">
<title>GREEN MOMENT · 7/25 정기 라운딩</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,400&family=Noto+Serif+KR:wght@200;300;400;600&family=Noto+Sans+KR:wght@200;300;400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --pine:#0A1D15;
    --pine-2:#0F2A1E;
    --pine-3:#143526;
    --gold:#C9A96A;
    --champagne:#E9D9B4;
    --ivory:#F5F0E6;
    --mist:#9DB3A6;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{
    background:#05110B;
    font-family:'Noto Sans KR',sans-serif;
    color:var(--ivory);
    display:flex;justify-content:center;
    padding:28px 12px;
  }
  .poster{
    width:100%;max-width:460px;
    background:
      radial-gradient(120% 60% at 50% 0%, rgba(201,169,106,.10) 0%, rgba(201,169,106,0) 55%),
      linear-gradient(180deg,var(--pine) 0%,var(--pine-2) 55%,var(--pine-3) 100%);
    position:relative;
    box-shadow:0 24px 80px rgba(0,0,0,.7);
    padding:14px;
    overflow:hidden;
  }
  /* ---------- night sky ---------- */
  .sky{position:absolute;inset:0;z-index:0;pointer-events:none;overflow:hidden}
  .milkyway{
    position:absolute;top:-14%;left:-32%;width:170%;height:74%;
    transform:rotate(-19deg);
    background:
      radial-gradient(ellipse 46% 50% at 32% 50%, rgba(233,217,180,.16) 0%, rgba(233,217,180,0) 70%),
      radial-gradient(ellipse 40% 44% at 66% 46%, rgba(201,169,106,.14) 0%, rgba(201,169,106,0) 72%),
      linear-gradient(180deg, rgba(157,179,166,0) 0%, rgba(200,214,205,.10) 46%, rgba(157,179,166,0) 100%);
    filter:blur(14px);
  }
  .milkyway.b{
    top:2%;left:-24%;width:150%;height:56%;
    transform:rotate(-15deg);opacity:.7;
    background:
      radial-gradient(ellipse 38% 46% at 48% 50%, rgba(233,217,180,.13) 0%, rgba(233,217,180,0) 70%);
    filter:blur(22px);
  }
  .stars{position:absolute;inset:0}
  .stars i{
    position:absolute;display:block;border-radius:50%;
    background:var(--ivory);
    opacity:.65;
  }
  /* ---------- ball trajectory ---------- */
  .trace{position:absolute;top:0;left:0;width:100%;height:340px}
  .trace path{
    stroke:url(#goldline);stroke-width:1.6;fill:none;stroke-linecap:round;
    stroke-width:2.2;
  }
  .trace .ball{
    fill:var(--ivory);opacity:1;
  }
  /* double gold frame */
  .frame{
    border:1.5px solid rgba(201,169,106,.62);
    position:relative;z-index:1;
    padding:40px 26px 150px;
  }
  .frame::before{
    content:"";position:absolute;inset:5px;
    border:1.5px solid rgba(201,169,106,.28);
    pointer-events:none;
  }
  /* corner flourishes */
  .corner{
    position:absolute;width:22px;height:22px;
    border-color:var(--gold);border-style:solid;border-width:0;
  }
  .corner.tl{top:-1px;left:-1px;border-top-width:3px;border-left-width:3px}
  .corner.tr{top:-1px;right:-1px;border-top-width:3px;border-right-width:3px}
  .corner.bl{bottom:-1px;left:-1px;border-bottom-width:3px;border-left-width:3px}
  .corner.br{bottom:-1px;right:-1px;border-bottom-width:3px;border-right-width:3px}

  /* ---------- hero ---------- */
  .crest{
    width:64px;height:64px;margin:0 auto 18px;
    border:1px solid rgba(201,169,106,.6);border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    position:relative;
  }
  .crest::before{
    content:"";position:absolute;inset:4px;border-radius:50%;
    border:1px solid rgba(201,169,106,.25);
  }
  .crest span{
    font-family:'Cormorant Garamond',serif;
    font-size:24px;letter-spacing:.08em;color:var(--champagne);
    font-weight:400;padding-left:.08em;
  }
  .eyebrow{
    text-align:center;
    font-family:'Cormorant Garamond',serif;
    font-size:13px;letter-spacing:.55em;text-transform:uppercase;
    color:var(--gold);padding-left:.55em;
    margin-bottom:16px;font-weight:500;
  }
  .title{
    text-align:center;
    font-family:'Noto Serif KR',serif;
    font-weight:300;font-size:34px;line-height:1.4;
    color:var(--ivory);letter-spacing:.06em;
  }
  .title b{font-weight:600;color:var(--champagne)}
  .date-line{
    margin-top:18px;text-align:center;
    font-family:'Cormorant Garamond',serif;
    font-size:17px;letter-spacing:.3em;color:var(--mist);padding-left:.3em;
  }
  .date-line b{color:var(--champagne);font-weight:500}
  .venue{
    margin-top:8px;text-align:center;
    font-size:15px;font-weight:400;letter-spacing:.22em;color:var(--ivory);padding-left:.28em;
  }

  .venue-addr{
    margin-top:8px;text-align:center;
    font-size:12.5px;font-weight:300;letter-spacing:.04em;color:var(--mist);
  }

  /* ---------- putting green at base ---------- */
  .green{
    position:absolute;left:0;right:0;bottom:0;height:210px;
    z-index:0;pointer-events:none;
  }
  .green .turf{
    position:absolute;left:-10%;right:-10%;bottom:0;height:170px;
    background:
      radial-gradient(ellipse 60% 90% at 50% 100%, rgba(95,150,110,.38) 0%, rgba(95,150,110,0) 72%),
      linear-gradient(180deg, rgba(20,53,38,0) 0%, rgba(26,68,48,.85) 42%, rgba(16,44,31,1) 100%);
    border-radius:100% 100% 0 0 / 62px 62px 0 0;
  }
  .green .sheen{
    position:absolute;left:12%;right:12%;bottom:16px;height:86px;
    background:radial-gradient(ellipse 50% 70% at 62% 40%, rgba(233,217,180,.13) 0%, rgba(233,217,180,0) 70%);
    filter:blur(6px);
  }
  .green svg{position:absolute;inset:0;width:100%;height:100%}

  /* ---------- dividers ---------- */
  .divider{
    display:flex;align-items:center;gap:14px;
    margin:30px 0 20px;
  }
  .divider::before,.divider::after{
    content:"";flex:1;height:1.5px;
    background:linear-gradient(90deg,transparent,rgba(201,169,106,.6));
  }
  .divider::after{background:linear-gradient(90deg,rgba(201,169,106,.5),transparent)}
  .divider .label{
    font-family:'Noto Serif KR',serif;font-weight:400;
    font-size:14px;letter-spacing:.36em;color:var(--gold);padding-left:.36em;
    white-space:nowrap;
  }
  .divider .diamond{
    width:5px;height:5px;background:var(--gold);
    transform:rotate(45deg);flex:none;
  }

  /* ---------- meet ---------- */
  .meet{
    display:flex;justify-content:center;gap:0;
  }
  .meet .cell{
    flex:1;text-align:center;padding:4px 10px;
  }
  .meet .cell + .cell{border-left:1.5px solid rgba(201,169,106,.32)}
  .meet .k{
    font-size:11px;font-weight:300;letter-spacing:.3em;color:var(--mist);padding-left:.3em;
    margin-bottom:8px;
  }
  .meet .v{
    font-family:'Cormorant Garamond',serif;
    font-size:30px;font-weight:400;color:var(--champagne);line-height:1;
  }
  .meet .v small{
    display:block;font-family:'Noto Sans KR';font-size:11.5px;
    font-weight:300;color:var(--ivory);margin-top:8px;letter-spacing:.08em;font-size:12.5px;
  }

  /* ---------- tee ---------- */
  .flight{
    display:flex;align-items:center;gap:14px;
    padding:14px 4px;
  }
  .flight + .flight{border-top:1.5px solid rgba(201,169,106,.24)}
  .flight .time{
    flex:0 0 70px;text-align:center;
  }
  .flight .time .t{
    font-family:'Cormorant Garamond',serif;
    font-size:28px;color:var(--champagne);line-height:1;font-weight:400;
  }
  .flight .time .o{
    font-size:9.5px;letter-spacing:.42em;color:var(--gold);margin-top:5px;padding-left:.42em;
  }
  .flight .who{border-left:1.5px solid rgba(201,169,106,.32);padding-left:14px;min-width:0}
  .flight .mates{
    font-family:'Noto Serif KR',serif;font-weight:400;
    font-size:15px;color:var(--ivory);letter-spacing:.04em;line-height:1.6;
    white-space:nowrap;
  }

  /* ---------- rules ---------- */
  .rules{list-style:none}
  .rules li{
    display:flex;gap:14px;align-items:baseline;
    padding:9px 2px;font-size:14px;font-weight:300;
    color:var(--ivory);line-height:1.65;
    word-break:keep-all;
  }
  .rules li + li{border-top:1.5px solid rgba(201,169,106,.18)}
  .rules .no{
    flex:0 0 26px;text-align:right;
    font-family:'Cormorant Garamond',serif;
    font-size:18px;color:var(--gold);font-style:italic;
  }
  .rules b{font-weight:500;color:var(--champagne)}
  .rules .sub{
    display:block;color:var(--mist);font-size:13px;margin-top:4px;line-height:1.75;
    font-weight:300;
  }

  /* ---------- tba ---------- */
  .award{
    text-align:center;padding:4px 6px 2px;
  }
  .award .k{font-size:12px;letter-spacing:.32em;color:var(--mist);padding-left:.32em;margin-bottom:10px;font-weight:300}
  .award .v{
    font-family:'Noto Serif KR',serif;font-weight:400;
    font-size:15px;color:var(--ivory);letter-spacing:.1em;line-height:1.7;
    word-break:keep-all;
  }
  .award .v b{font-weight:600;color:var(--champagne)}

  .dine{text-align:center;padding:4px 6px 18px;border-bottom:1.5px solid rgba(201,169,106,.24)}
  .dine .k{font-size:12px;letter-spacing:.32em;color:var(--mist);padding-left:.32em;margin-bottom:10px;font-weight:300}
  .dine .name{
    font-family:'Noto Serif KR',serif;font-weight:600;
    font-size:19px;color:var(--champagne);letter-spacing:.12em;
  }
  .dine .addr{
    margin-top:9px;font-size:13.5px;font-weight:300;
    color:var(--mist);letter-spacing:.04em;line-height:1.6;
  }
  .after{text-align:center;padding:16px 6px 2px}
  .after .k{font-size:12px;letter-spacing:.32em;color:var(--mist);padding-left:.32em;margin-bottom:8px;font-weight:300}
  .after .v{
    font-family:'Noto Serif KR',serif;font-size:14.5px;
    color:var(--ivory);font-weight:300;letter-spacing:.2em;
  }

  /* ---------- closing ---------- */
  .closing{
    margin-top:30px;text-align:center;
    font-family:'Noto Serif KR',serif;font-weight:300;
    font-size:14.5px;color:var(--ivory);line-height:2;letter-spacing:.14em;
  }
  .closing b{font-weight:600;color:var(--champagne)}
  .fin{
    margin-top:16px;display:flex;align-items:center;gap:12px;justify-content:center;
  }
  .fin::before,.fin::after{
    content:"";width:52px;height:1.5px;background:rgba(201,169,106,.5);
  }
  .fin .diamond{width:4px;height:4px;background:var(--gold);transform:rotate(45deg)}
</style>
</head>
<body>
<div class="poster">
  <div class="sky">
    <div class="milkyway"></div>
    <div class="milkyway b"></div>
    <div class="stars">
      <i style="width:2px;height:2px;top:5%;left:9%"></i>
      <i style="width:1.5px;height:1.5px;top:8%;left:23%;animation-delay:.6s"></i>
      <i style="width:2.5px;height:2.5px;top:4%;left:41%;animation-delay:1.9s"></i>
      <i style="width:1.5px;height:1.5px;top:11%;left:57%;animation-delay:.3s"></i>
      <i style="width:2px;height:2px;top:6%;left:73%;animation-delay:2.4s"></i>
      <i style="width:1.5px;height:1.5px;top:13%;left:88%;animation-delay:1.2s"></i>
      <i style="width:2px;height:2px;top:17%;left:15%;animation-delay:2.8s"></i>
      <i style="width:1.5px;height:1.5px;top:21%;left:34%;animation-delay:.9s"></i>
      <i style="width:2px;height:2px;top:19%;left:64%;animation-delay:1.6s"></i>
      <i style="width:1.5px;height:1.5px;top:25%;left:81%;animation-delay:.2s"></i>
      <i style="width:2px;height:2px;top:29%;left:6%;animation-delay:2.1s"></i>
      <i style="width:1.5px;height:1.5px;top:33%;left:47%;animation-delay:1.4s"></i>
      <i style="width:2px;height:2px;top:37%;left:92%;animation-delay:.7s"></i>
      <i style="width:1.5px;height:1.5px;top:44%;left:28%;animation-delay:2.6s"></i>
      <i style="width:1.5px;height:1.5px;top:52%;left:71%;animation-delay:1.1s"></i>
      <i style="width:2px;height:2px;top:61%;left:12%;animation-delay:.5s"></i>
      <i style="width:1.5px;height:1.5px;top:70%;left:86%;animation-delay:2.2s"></i>
      <i style="width:1.5px;height:1.5px;top:79%;left:38%;animation-delay:1.7s"></i>
    </div>
    <svg class="trace" viewBox="0 0 460 340" preserveAspectRatio="none">
      <defs>
        <linearGradient id="goldline" x1="0" y1="1" x2="1" y2="0">
          <stop offset="0%" stop-color="#C9A96A" stop-opacity="0"/>
          <stop offset="35%" stop-color="#C9A96A" stop-opacity=".55"/>
          <stop offset="75%" stop-color="#E9D9B4" stop-opacity=".95"/>
          <stop offset="100%" stop-color="#F5F0E6" stop-opacity="1"/>
        </linearGradient>
        <filter id="glow" x="-60%" y="-60%" width="220%" height="220%">
          <feGaussianBlur stdDeviation="4" result="b"/>
          <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
      </defs>
      <path d="M -20 330 C 110 300, 210 190, 300 96 S 420 26, 470 14" filter="url(#glow)"/>
      <circle class="ball" cx="452" cy="17" r="3.4" filter="url(#glow)"/>
    </svg>
    <div class="green">
      <div class="turf"></div>
      <div class="sheen"></div>
      <svg viewBox="0 0 460 210" preserveAspectRatio="xMidYMax slice">
        <defs>
          <!-- mown turf texture -->
          <linearGradient id="mow" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#1B4832" stop-opacity=".0"/>
            <stop offset="50%" stop-color="#2A6244" stop-opacity=".22"/>
            <stop offset="100%" stop-color="#1B4832" stop-opacity="0"/>
          </linearGradient>
          <!-- depression shading around cup -->
          <radialGradient id="dip" cx="50%" cy="50%" r="50%">
            <stop offset="55%" stop-color="#0B2318" stop-opacity=".55"/>
            <stop offset="100%" stop-color="#0B2318" stop-opacity="0"/>
          </radialGradient>
          <!-- cup interior: dark, deepest at near-bottom -->
          <radialGradient id="cupDepth" cx="50%" cy="16%" r="98%">
            <stop offset="0%" stop-color="#12301F"/>
            <stop offset="34%" stop-color="#081A11"/>
            <stop offset="100%" stop-color="#020905"/>
          </radialGradient>
          <!-- white liner catching moonlight on far wall -->
          <linearGradient id="liner" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#E9E2CE" stop-opacity=".85"/>
            <stop offset="45%" stop-color="#9AA391" stop-opacity=".45"/>
            <stop offset="100%" stop-color="#0A1C12" stop-opacity="0"/>
          </linearGradient>
          <!-- crisp turf edge highlight -->
          <linearGradient id="rimLight" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#F5F0E6" stop-opacity=".15"/>
            <stop offset="100%" stop-color="#F5F0E6" stop-opacity=".75"/>
          </linearGradient>
          <linearGradient id="poleG" x1="0" y1="1" x2="0" y2="0">
            <stop offset="0%" stop-color="#8E7C4F" stop-opacity=".8"/>
            <stop offset="35%" stop-color="#C9A96A" stop-opacity=".9"/>
            <stop offset="100%" stop-color="#F5F0E6" stop-opacity=".98"/>
          </linearGradient>
          <linearGradient id="flagG" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#E9D9B4"/>
            <stop offset="55%" stop-color="#C9A96A"/>
            <stop offset="100%" stop-color="#9C7F45"/>
          </linearGradient>
          <filter id="soft" x="-40%" y="-40%" width="180%" height="180%">
            <feGaussianBlur stdDeviation="1.6"/>
          </filter>
          <filter id="softer" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="4"/>
          </filter>
        </defs>

        <!-- mowing stripes -->
        <g opacity=".5">
          <ellipse cx="230" cy="196" rx="240" ry="34" fill="url(#mow)"/>
          <ellipse cx="230" cy="176" rx="215" ry="26" fill="url(#mow)"/>
          <ellipse cx="230" cy="158" rx="185" ry="20" fill="url(#mow)"/>
        </g>

        <!-- ground contact shadow of the pin, cast away from moon -->
        <ellipse cx="272" cy="173" rx="46" ry="7" fill="#04120B" opacity=".35" filter="url(#softer)"/>
        <path d="M300 172 L214 168 L210 172 L300 176 Z" fill="#04120B" opacity=".3" filter="url(#soft)"/>

        <!-- slight depression around the cup -->
        <ellipse cx="300" cy="171" rx="34" ry="13" fill="url(#dip)"/>

        <!-- cup opening -->
        <ellipse cx="300" cy="171" rx="16" ry="5.6" fill="url(#cupDepth)"/>
        <!-- lit far inner wall (liner) -->
        <path d="M284.6 170 A16 5.6 0 0 1 315.4 170 L315.4 172.4 A16 5.6 0 0 0 284.6 172.4 Z" fill="url(#liner)"/>
        <!-- flagstick continues into the cup -->
        <rect x="299.1" y="168" width="1.8" height="5" fill="#2A2418" opacity=".9"/>
        <!-- near rim: sharp cut turf edge lit by moonlight -->
        <path d="M284 171 A16 5.6 0 0 0 316 171" fill="none" stroke="url(#rimLight)" stroke-width="1.5" stroke-linecap="round"/>
        <!-- far rim: subtle darker line where turf meets liner -->
        <path d="M284 171 A16 5.6 0 0 1 316 171" fill="none" stroke="#0A1F14" stroke-width="1.1" opacity=".9"/>
        <!-- ragged grass fringe at the lip -->
        <g stroke="#5F9B6E" stroke-width=".9" stroke-linecap="round" opacity=".55">
          <path d="M287 173.4 l-1.6 2.4"/><path d="M292 175 l-.8 2.6"/>
          <path d="M297 175.8 l.4 2.6"/><path d="M303 175.8 l.9 2.4"/>
          <path d="M308.5 174.6 l1.7 2.3"/><path d="M313 172.6 l2.2 1.9"/>
          <path d="M289.5 174.6 l-2 2"/>
        </g>

        <!-- flagstick -->
        <rect x="299.2" y="70" width="1.7" height="100" fill="url(#poleG)"/>
        <rect x="299.2" y="112" width="1.7" height="3" fill="#E9D9B4" opacity=".9"/>
        <!-- flag, gently furled -->
        <path d="M301 72 C316 75, 328 79, 341 78 C332 84, 322 88, 301 92 Z" fill="url(#flagG)"/>
        <path d="M301 72 C316 75, 328 79, 341 78" fill="none" stroke="#F5F0E6" stroke-width=".7" opacity=".35"/>
      </svg>
    </div>
  </div>
  <div class="frame">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>

    <div class="crest"><span>GM</span></div>
